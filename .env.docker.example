# ============================================================
# CienciasNET — Variables de Entorno para Docker
# ============================================================
# Copiar este archivo a .env y ajustar los valores

# ----------------------------------------------------------
# Aplicación
# ----------------------------------------------------------
APP_URL=https://api.cienciascolegio.pe
APP_ENV=production
APP_DEBUG=false
APP_KEY=          # Se genera automáticamente en el entrypoint

# ----------------------------------------------------------
# Base de Datos (PostgreSQL — servicio "db")
# ----------------------------------------------------------
DB_DATABASE=cienciasnet
DB_USERNAME=cienciasnet_user
DB_PASSWORD=change_me

# ----------------------------------------------------------
# Frontend
# ----------------------------------------------------------
VITE_API_URL=https://api.cienciascolegio.pe
FRONTEND_PORT=8080

# ----------------------------------------------------------
# Correo — Gmail SMTP (cuenta del colegio)
# ----------------------------------------------------------
# REQUISITOS para usar Gmail como servidor SMTP:
#   1. Activar verificación en 2 pasos en la cuenta Gmail del colegio
#   2. Generar un "App Password" en myaccount.google.com/apppasswords
#      (Tipo: "Correo", Dispositivo: "Otra (CienciasNET)")
#   3. Usar ese password de 16 caracteres como MAIL_PASSWORD
# IMPORTANTE: MAIL_FROM_ADDRESS debe ser IGUAL a MAIL_USERNAME.
#   Gmail no permite enviar como otra dirección (no spoofing).
#
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=colegio.ciencias@gmail.com
MAIL_PASSWORD=aaaa_bbbb_cccc_dddd
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=${MAIL_USERNAME}
MAIL_FROM_NAME="Colegio Ciencias"
MAIL_SUBJECT_PREFIX="[CienciasNET] "

# ----------------------------------------------------------
# Sanctum (SPA Authentication)
# ----------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=cienciascolegio.pe
SESSION_DOMAIN=.cienciascolegio.pe
CORS_ALLOWED_ORIGINS=https://cienciascolegio.pe

# Copy to a protected location outside the repository, for example:
# /etc/cienciasnet/production.env
#
# Never commit the real production file.

APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.cienciascolegio.pe
FRONTEND_URL=https://cienciascolegio.pe
SANCTUM_STATEFUL_DOMAINS=cienciascolegio.pe

APP_KEY=base64:change_me

DB_DATABASE=cienciasnet
DB_USERNAME=cienciasnet
DB_PASSWORD=change_me

FACIAL_SERVICE_TOKEN=change_me_long_random_token
FACIAL_SERVICE_TIMEOUT=5

BIOMETRIC_ENCRYPTION_KEY=change_me_independent_key
R2_ENDPOINT=https://account-id.r2.cloudflarestorage.com
R2_BUCKET=cienciasnet-biometria
R2_ACCESS_KEY_ID=change_me
R2_SECRET_ACCESS_KEY=change_me

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=colegio.ciencias@gmail.com
MAIL_PASSWORD=change_me_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=colegio.ciencias@gmail.com
MAIL_FROM_NAME=Colegio Ciencias
MAIL_SUBJECT_PREFIX=[CienciasNET]

BACKUP_ROOT=/backups/cienciasnet
BACKUP_RETENTION_DAILY=30
BACKUP_RETENTION_MONTHLY=12
BACKUP_ENCRYPTION_PASSPHRASE_FILE=/run/secrets/backup_passphrase
BACKUP_ALERT_WEBHOOK_URL=
